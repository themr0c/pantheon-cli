#!/usr/bin/env python3
"""Explore DXP DSPM splash page API by navigating through Pantheon (authenticated).

Navigates to Pantheon's splash page section, waits for the DSPM iframe to load,
and captures all network requests + evaluates JS inside the iframe.
READ-ONLY: never modifies any data.
"""

import os
import sys
import json
import time
from pathlib import Path

# Re-exec under the repo venv if not already running from it
_script = Path(__file__).resolve()
_repo_root = _script.parent.parent
_venv_python = _repo_root / 'venv' / 'bin' / 'python'
if _venv_python.is_file() and Path(sys.executable).resolve() != _venv_python.resolve():
    os.execv(str(_venv_python), [str(_venv_python), str(_script)] + sys.argv[1:])

# Load .env from repo root
_env_file = _repo_root / '.env'
if _env_file.is_file():
    for line in _env_file.read_text().splitlines():
        line = line.strip()
        if line and not line.startswith('#') and '=' in line:
            k, v = line.split('=', 1)
            os.environ[k.strip()] = v.strip()

from playwright.sync_api import sync_playwright

PANTHEON_URL = "https://pantheon.cee.redhat.com/"
SESSION_DIR = str(Path.home() / ".cache" / "pantheon-explore-dspm-via-pantheon")
DSPM_DOMAIN = "dxp-dspm-prod.apps.int.drop.prod.us-west-2.aws.paas.redhat.com"

# Capture all network requests to the DSPM domain
dspm_requests = []

def on_request(request):
    if DSPM_DOMAIN in request.url:
        dspm_requests.append({
            'method': request.method,
            'url': request.url,
            'resource_type': request.resource_type,
        })

def on_response(response):
    if DSPM_DOMAIN in response.url:
        # Find matching request and add response info
        for req in dspm_requests:
            if req['url'] == response.url and 'status' not in req:
                req['status'] = response.status
                req['content_type'] = response.headers.get('content-type', '')
                # Capture body for non-asset responses
                if req['resource_type'] in ('document', 'xhr', 'fetch', 'other'):
                    try:
                        body = response.text()
                        if len(body) < 50000:
                            req['body'] = body
                        else:
                            req['body_preview'] = body[:2000] + '...[truncated]'
                    except:
                        req['body'] = '<could not read>'
                break


def _check_authenticated(page):
    """Check if the current session is authenticated with Pantheon."""
    try:
        return page.evaluate("""() => {
            return new Promise((resolve) => {
                const xhr = new XMLHttpRequest();
                xhr.open('GET', 'https://pantheon.cee.redhat.com/auth/check_login', true);
                xhr.withCredentials = true;
                xhr.onload = () => resolve(xhr.status);
                xhr.onerror = () => resolve(0);
                xhr.send();
            });
        }""") == 200
    except Exception:
        return False


def _sso_login(page, email):
    """Complete the SSO login form: remove overlays, enter email, click SSO."""
    page.evaluate(
        "() => document.querySelectorAll('.truste_box_overlay, .truste_cm_outerdiv, "
        ".truste_overlay, [class*=\"truste\"], #teconsent').forEach(e => e.remove())"
    )
    time.sleep(1)

    username = page.locator("#username-verification")
    if username.count() > 0 and username.first.is_visible():
        print(f"  Entering email: {email}")
        username.first.fill(email)
        time.sleep(0.5)
        next_btn = page.locator("#login-show-step2")
        if next_btn.count() > 0 and next_btn.first.is_visible():
            next_btn.first.click()
            time.sleep(2)
        sso_btn = page.locator("#rh-sso-flow")
        if sso_btn.count() > 0 and sso_btn.first.is_visible():
            print("  Clicking 'Log in with company single sign-on'...")
            sso_btn.first.click()
            time.sleep(5)
            return True
    return False


def login_and_wait(page, email):
    """Navigate to Pantheon, automate SSO login, wait for auth."""
    print("Navigating to Pantheon...")
    page.goto(PANTHEON_URL, wait_until="domcontentloaded", timeout=60000)
    time.sleep(5)

    if _check_authenticated(page):
        print("Already authenticated (session still valid).")
        return True

    # Remove cookie overlays
    time.sleep(3)
    try:
        page.evaluate(
            "() => document.querySelectorAll('.truste_box_overlay, .truste_cm_outerdiv, "
            ".truste_overlay, [class*=\"truste\"], #teconsent').forEach(e => e.remove())"
        )
    except Exception:
        time.sleep(2)
    time.sleep(1)

    # Click Login link
    clicked = page.evaluate("""() => {
        const links = document.querySelectorAll('a');
        for (const a of links) {
            const text = a.textContent.trim();
            if (text === 'Login' || text === 'Log in') { a.click(); return true; }
        }
        return false;
    }""")
    if clicked:
        print("Clicking Login...")
        time.sleep(5)

    # Complete SSO login form
    if 'sso.redhat.com' in page.url:
        _sso_login(page, email)

    # Wait for SSO redirect
    print("  Waiting for SSO to complete...")
    for i in range(60):
        time.sleep(2)
        if 'pantheon.cee.redhat.com' in page.url:
            if _check_authenticated(page):
                print("Authenticated!")
                return True
        if (i + 1) % 10 == 0:
            print(f"  Still waiting... ({(i+1)*2}s)")

    print("ERROR: Login timed out.")
    return False


def explore_splash_page(page, product, version, env_name):
    """Navigate to a splash page and capture DSPM iframe data."""
    print(f"\n{'='*60}")
    print(f"Exploring splash page: {product}/{version}/{env_name}")
    print(f"{'='*60}")

    splash_url = f"{PANTHEON_URL}#/splash-pages/{product}/{version}/{env_name}"
    print(f"Navigating to: {splash_url}")
    page.goto(splash_url, wait_until="domcontentloaded", timeout=30000)

    # Wait for iframe to appear
    print("Waiting for DSPM iframe to load...")
    time.sleep(5)

    # Check for iframe
    iframe_info = page.evaluate("""() => {
        const iframe = document.querySelector('#splash-page-frame, iframe.splash-page-frame');
        if (!iframe) return { found: false, iframes: document.querySelectorAll('iframe').length };
        return {
            found: true,
            src: iframe.src,
            width: iframe.offsetWidth,
            height: iframe.offsetHeight,
        };
    }""")

    print(f"Iframe info: {json.dumps(iframe_info, indent=2)}")

    if not iframe_info.get('found'):
        print("No splash page iframe found. Checking page content...")
        # Maybe auth issue or permission issue
        page_text = page.evaluate("() => document.body.innerText.substring(0, 2000)")
        print(f"Page text: {page_text}")
        return None

    # Wait a bit more for iframe content to load
    time.sleep(5)

    # Try to access iframe content
    frames = page.frames
    print(f"\nPage has {len(frames)} frames:")
    for i, frame in enumerate(frames):
        print(f"  Frame {i}: {frame.url[:120]}")

    # Find the DSPM iframe
    dspm_frame = None
    for frame in frames:
        if DSPM_DOMAIN in frame.url:
            dspm_frame = frame
            break

    if not dspm_frame:
        print("Could not find DSPM frame!")
        return None

    print(f"\nDSPM frame URL: {dspm_frame.url}")

    # Evaluate JavaScript inside the DSPM iframe
    results = {}

    # 1. Get page structure/HTML overview
    try:
        html_structure = dspm_frame.evaluate("""() => {
            const result = {};

            // Get all forms
            const forms = document.querySelectorAll('form');
            result.forms = Array.from(forms).map(f => ({
                action: f.action,
                method: f.method,
                id: f.id,
                classes: f.className,
                inputs: Array.from(f.querySelectorAll('input, select, textarea')).map(i => ({
                    type: i.type, name: i.name, id: i.id, value: i.value?.substring(0, 100)
                }))
            }));

            // Get all links
            const links = document.querySelectorAll('a[href]');
            result.links = Array.from(links).map(a => ({
                href: a.href, text: a.textContent.trim().substring(0, 100)
            })).filter(l => l.href && !l.href.startsWith('javascript:'));

            // Get all buttons
            const buttons = document.querySelectorAll('button, input[type="submit"]');
            result.buttons = Array.from(buttons).map(b => ({
                text: b.textContent?.trim().substring(0, 100) || b.value,
                type: b.type,
                id: b.id,
                classes: b.className
            }));

            // Get categories/sections structure
            const categories = document.querySelectorAll('[class*="category"], [class*="group"], [data-category]');
            result.categories_elements = Array.from(categories).map(c => ({
                tag: c.tagName,
                classes: c.className,
                id: c.id,
                text: c.textContent?.trim().substring(0, 200)
            }));

            // Get all data attributes
            const allElements = document.querySelectorAll('[data-drupal-selector], [data-entity-id], [data-id]');
            result.data_elements = Array.from(allElements).map(e => ({
                tag: e.tagName,
                id: e.id,
                dataset: Object.fromEntries(Object.entries(e.dataset).map(([k, v]) => [k, v?.substring(0, 100)]))
            }));

            // Page title
            result.title = document.title;

            // All script sources
            result.scripts = Array.from(document.querySelectorAll('script[src]')).map(s => s.src);

            // drupalSettings if available
            if (window.drupalSettings) {
                result.drupalSettings = JSON.stringify(window.drupalSettings).substring(0, 5000);
            }

            // Check for Drupal.behaviors
            if (window.Drupal && window.Drupal.behaviors) {
                result.drupalBehaviors = Object.keys(window.Drupal.behaviors);
            }

            return result;
        }""")
        results['html_structure'] = html_structure
        print(f"\n--- HTML Structure ---")
        print(json.dumps(html_structure, indent=2, default=str))
    except Exception as e:
        print(f"Error evaluating iframe HTML structure: {e}")

    # 2. Look for AJAX/API endpoints in JS
    try:
        js_analysis = dspm_frame.evaluate("""() => {
            const result = {};

            // Check for jQuery AJAX settings
            if (window.jQuery && window.jQuery.ajaxSettings) {
                result.ajaxSettings = {
                    url: window.jQuery.ajaxSettings.url,
                    type: window.jQuery.ajaxSettings.type,
                };
            }

            // Check Drupal ajax instances
            if (window.Drupal && window.Drupal.ajax && window.Drupal.ajax.instances) {
                result.ajaxInstances = window.Drupal.ajax.instances
                    .filter(i => i)
                    .map(i => ({
                        url: i.url,
                        selector: i.selector,
                        event: i.event,
                        progress: i.progress,
                    }));
            }

            // Check for any fetch/XHR interceptors or API configs
            if (window.drupalSettings) {
                // Look for API-related settings
                const settings = window.drupalSettings;
                result.basePath = settings.path?.baseUrl;
                result.pathPrefix = settings.path?.pathPrefix;
                result.currentPath = settings.path?.currentPath;
                result.ajaxPageState = settings.ajaxPageState;
                result.user = settings.user;

                // Look for custom module settings
                const customKeys = Object.keys(settings).filter(k =>
                    !['path', 'ajaxPageState', 'user', 'pluralDelimiter'].includes(k)
                );
                result.customSettings = {};
                for (const k of customKeys) {
                    result.customSettings[k] = JSON.stringify(settings[k]).substring(0, 500);
                }
            }

            return result;
        }""")
        results['js_analysis'] = js_analysis
        print(f"\n--- JS Analysis ---")
        print(json.dumps(js_analysis, indent=2, default=str))
    except Exception as e:
        print(f"Error evaluating iframe JS: {e}")

    # 3. Get visible content (categories, titles)
    try:
        visible_content = dspm_frame.evaluate("""() => {
            const result = {};

            // Try to find the main content area
            const main = document.querySelector('main, .main-content, #main-content, .layout-content');
            if (main) {
                result.mainHTML = main.innerHTML.substring(0, 10000);
            }

            // Get all text content organized by headings
            const headings = document.querySelectorAll('h1, h2, h3, h4, h5, h6');
            result.headings = Array.from(headings).map(h => ({
                level: h.tagName,
                text: h.textContent.trim()
            }));

            // Look for drag-and-drop elements (common in splash page managers)
            const draggables = document.querySelectorAll('[draggable], .draggable, .sortable, [class*="drag"]');
            result.draggables = Array.from(draggables).map(d => ({
                tag: d.tagName,
                classes: d.className,
                text: d.textContent?.trim().substring(0, 100)
            }));

            // Look for table rows (Drupal often uses tables for admin)
            const tables = document.querySelectorAll('table');
            result.tables = Array.from(tables).map(t => ({
                id: t.id,
                classes: t.className,
                rows: t.rows.length,
                headerCells: Array.from(t.querySelectorAll('th')).map(th => th.textContent.trim()),
                firstRowCells: t.rows.length > 1 ?
                    Array.from(t.rows[1].cells).map(td => td.textContent.trim().substring(0, 100)) : []
            }));

            // Full body text (condensed)
            result.bodyText = document.body.innerText.substring(0, 5000);

            return result;
        }""")
        results['visible_content'] = visible_content
        print(f"\n--- Visible Content ---")
        print(json.dumps(visible_content, indent=2, default=str))
    except Exception as e:
        print(f"Error evaluating iframe visible content: {e}")

    # 4. Read the custom JS files content
    for script_url in results.get('html_structure', {}).get('scripts', []):
        if '/custom/' in script_url or '/spm/' in script_url:
            try:
                js_content = dspm_frame.evaluate(f"""() => {{
                    return new Promise((resolve) => {{
                        const xhr = new XMLHttpRequest();
                        xhr.open('GET', '{script_url}', true);
                        xhr.onload = () => resolve(xhr.responseText);
                        xhr.onerror = () => resolve('ERROR: ' + xhr.status);
                        xhr.send();
                    }});
                }}""")
                print(f"\n--- JS File: {script_url} ---")
                print(js_content[:5000])
                results[f'js_{script_url.split("/")[-1]}'] = js_content[:5000]
            except Exception as e:
                print(f"Error reading {script_url}: {e}")

    return results


def main():
    print("Starting DXP DSPM exploration via Pantheon...")

    with sync_playwright() as p:
        # Headed mode required for Kerberos SPNEGO initial authentication
        context = p.firefox.launch_persistent_context(
            SESSION_DIR,
            headless=False,
            ignore_https_errors=True,
            viewport={'width': 1920, 'height': 1080},
            firefox_user_prefs={
                "network.negotiate-auth.trusted-uris": ".redhat.com,.cee.redhat.com",
            },
        )
        page = context.pages[0] if context.pages else context.new_page()

        # Set up request/response interception
        page.on('request', on_request)
        page.on('response', on_response)

        # Authenticate
        email = os.environ.get('SSO_EMAIL', '')
        if not email:
            print("ERROR: SSO_EMAIL not set in .env")
            context.close()
            sys.exit(1)

        if not login_and_wait(page, email):
            print("FATAL: Cannot authenticate with Pantheon")
            context.close()
            sys.exit(1)

        # Explore configured splash page (1.9/stage)
        results_19 = explore_splash_page(page, "red_hat_developer_hub", "1.9", "stage")

        # Explore unconfigured splash page (1.10/stage)
        results_110 = explore_splash_page(page, "red_hat_developer_hub", "1.10", "stage")

        # Print all captured DSPM network requests
        print(f"\n{'='*60}")
        print(f"CAPTURED DSPM NETWORK REQUESTS ({len(dspm_requests)} total)")
        print(f"{'='*60}")
        for req in dspm_requests:
            if req['resource_type'] in ('document', 'xhr', 'fetch', 'other'):
                print(f"\n  {req.get('method', '?')} {req['url']}")
                print(f"  Status: {req.get('status', '?')} | Type: {req['resource_type']} | Content-Type: {req.get('content_type', '?')}")
                if 'body' in req:
                    body = req['body']
                    if len(body) > 3000:
                        body = body[:3000] + '...[truncated]'
                    print(f"  Body preview: {body[:500]}")

        # Print summary of all DSPM requests (including assets)
        print(f"\n--- All DSPM request URLs ---")
        for req in dspm_requests:
            status = req.get('status', '?')
            print(f"  [{status}] {req.get('method', '?')} {req['url'][:150]}")

        context.close()
        print("\nExploration complete.")


if __name__ == '__main__':
    main()
