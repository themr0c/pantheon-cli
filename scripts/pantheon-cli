#!/usr/bin/env python3
"""Pantheon CLI for docs publishing operations.

Automate Pantheon build configuration and rebuilds via the Reef API.
Requires a valid Kerberos ticket (kinit) and VPN access.
"""

import os
import sys
from pathlib import Path

# Re-exec under the pantheon-cli venv if not already running from it
_script = Path(__file__).resolve()
_venv_dir = Path.home() / '.cache' / 'pantheon-cli' / 'venv'
_venv_python = _venv_dir / 'bin' / 'python'
if _venv_python.is_file() and sys.prefix != str(_venv_dir):
    os.execv(str(_venv_python), [str(_venv_python), str(_script)] + sys.argv[1:])

import time
import json
import shutil
import argparse
import subprocess
import re

# Load .env from user config
_env_file = Path.home() / '.config' / 'pantheon-cli' / '.env'
if _env_file.is_file():
    for line in _env_file.read_text().splitlines():
        line = line.strip()
        if line and not line.startswith('#') and '=' in line:
            k, v = line.split('=', 1)
            os.environ[k.strip()] = v.strip()

import requests
from playwright.sync_api import sync_playwright, TimeoutError as PWTimeout

# Constants
PANTHEON_URL = "https://pantheon.cee.redhat.com/"
REEF_API = "https://reef.corp.redhat.com/api"
CACHE_DIR = Path.home() / ".cache"


# ---------------------------------------------------------------------------
# Kerberos check
# ---------------------------------------------------------------------------

def check_kerberos():
    """Warn if no valid Kerberos ticket is found."""
    try:
        result = subprocess.run(
            ["klist", "-s"], capture_output=True, timeout=5
        )
        if result.returncode != 0:
            print("WARNING: No valid Kerberos ticket found. Run 'kinit' first.")
            print("         SSO login may fail without a ticket.\n")
    except FileNotFoundError:
        print("WARNING: 'klist' not found. Cannot verify Kerberos ticket.\n")


# ---------------------------------------------------------------------------
# Browser / Auth layer
# ---------------------------------------------------------------------------

def reef_get(session, endpoint):
    """GET request to Reef API via requests session."""
    url = f"{REEF_API}/{endpoint}"
    r = session.get(url, timeout=30)
    if r.status_code != 200:
        raise RuntimeError(
            f"Reef GET {endpoint}: HTTP {r.status_code}: {r.text[:200]}"
        )
    return r.json()


def _check_authenticated(page):
    """Check if the current session is authenticated with Pantheon."""
    try:
        return page.evaluate("""() => {
            return new Promise((resolve) => {
                const xhr = new XMLHttpRequest();
                xhr.open('GET', 'https://pantheon.cee.redhat.com/auth/check_login', true);
                xhr.withCredentials = true;
                xhr.onload = () => resolve(xhr.status);
                xhr.onerror = () => resolve(0);
                xhr.send();
            });
        }""") == 200
    except Exception:
        return False


def _sso_login(page, email):
    """Complete the SSO login form: remove overlays, enter email, click SSO."""
    _dismiss_trustarc(page)
    time.sleep(1)

    username = page.locator("#username-verification")
    if username.count() > 0 and username.first.is_visible():
        print(f"  Entering email: {email}")
        username.first.fill(email)
        time.sleep(0.5)
        next_btn = page.locator("#login-show-step2")
        if next_btn.count() > 0 and next_btn.first.is_visible():
            next_btn.first.click()
            time.sleep(2)
        sso_btn = page.locator("#rh-sso-flow")
        if sso_btn.count() > 0 and sso_btn.first.is_visible():
            print("  Clicking 'Log in with company single sign-on'...")
            sso_btn.first.click()
            time.sleep(5)
            return True
    return False


def login_and_wait(page, email):
    """Navigate to Pantheon, automate SSO login, wait for auth."""
    print("Navigating to Pantheon...")
    page.goto(PANTHEON_URL, wait_until="domcontentloaded", timeout=60000)
    time.sleep(5)

    if _check_authenticated(page):
        print("Already authenticated (session still valid).")
        return True

    # Wait for page to settle, dismiss cookie consent
    time.sleep(3)
    _dismiss_trustarc(page)
    time.sleep(1)

    # Click Login via JS to bypass any remaining overlays
    clicked = page.evaluate("""() => {
        const links = document.querySelectorAll('a');
        for (const a of links) {
            const text = a.textContent.trim();
            if (text === 'Login' || text === 'Log in') { a.click(); return true; }
        }
        return false;
    }""")
    if clicked:
        print("Clicking Login...")
        time.sleep(5)

    # Complete SSO login form
    if 'sso.redhat.com' in page.url:
        _sso_login(page, email)

    # Wait for SSO redirect back to Pantheon
    print("  Waiting for SSO to complete...")
    for i in range(60):
        time.sleep(2)
        if 'pantheon.cee.redhat.com' in page.url:
            if _check_authenticated(page):
                print("Authenticated!")
                return True
        if (i + 1) % 10 == 0:
            print(f"  Still waiting... ({(i+1)*2}s)")

    print("ERROR: Login timed out. Complete SSO manually in the browser window.")
    for i in range(60):
        time.sleep(2)
        try:
            if _check_authenticated(page):
                print("Authenticated!")
                return True
        except Exception:
            pass

    print("ERROR: Login timed out after 4 minutes.")
    return False


# ---------------------------------------------------------------------------
# Reef service wrappers
# ---------------------------------------------------------------------------

def get_titles(session, product, version):
    """Get all titles for a product/version."""
    data = reef_get(
        session,
        f"lightblue/get_titles?combineBrewed=false&lang=en-US"
        f"&product={product}&version={version}"
    )
    return data['data']['products'][0]['versions'][0]['titles']


def get_build_config(session, uuid, env="preview"):
    """Get current build config for a title."""
    data = reef_get(
        session,
        f"lightblue/get_title_build_config?uuid={uuid}&lang=en-US&environment={env}"
    )
    return data.get('data', {})


def update_build_config(session, uuid, env, branch, content_dir, content_type="book"):
    """Update build config via direct Reef API call.

    Endpoint verified via scripts/discover-reef-api — update URL if discovery
    output shows a different path.
    Note: API expects snake_case (content_directory, content_type).
    """
    r = session.post(
        f"{REEF_API}/lightblue/update_title_build_config",
        json={
            "uuid": uuid,
            "language": "en-US",
            "environment": env,
            "branch": branch,
            "content_directory": content_dir,
            "content_type": content_type,
        },
    )
    if not r.ok:
        raise RuntimeError(
            f"Update failed (HTTP {r.status_code}): {r.text[:300]}"
        )
    return r.json()


def toggle_job(session, job_name, enable):
    """Enable or disable a Jenkins job via direct Reef API call.

    disabled=False means enabled. Endpoint verified via scripts/discover-reef-api.
    """
    r = session.post(
        f"{REEF_API}/jenkins/toggle_job",
        json={
            "name": job_name,
            "disabled": not enable,
        },
    )
    if not r.ok:
        return {"ok": False, "error": f"HTTP {r.status_code}: {r.text[:300]}"}
    return {"ok": True}


def start_build(session, job_name):
    """Trigger a Jenkins build via direct Reef API call.

    Endpoint verified via scripts/discover-reef-api.
    """
    r = session.post(
        f"{REEF_API}/jenkins/start_job",
        json={"name": job_name},
    )
    if not r.ok:
        return {"ok": False, "error": f"HTTP {r.status_code}: {r.text[:300]}"}
    return {"ok": True}


# ---------------------------------------------------------------------------
# Title filtering
# ---------------------------------------------------------------------------

def filter_titles(titles, patterns):
    """Filter titles by case-insensitive substring match.

    patterns is a list of strings. A title matches if any pattern is a
    substring of the title name. If patterns is None or contains 'all',
    all titles are returned.
    """
    if not patterns or 'all' in patterns:
        return titles
    return [
        t for t in titles
        if any(p.lower() in t['name'].lower() for p in patterns)
    ]


# ---------------------------------------------------------------------------
# Browser context manager
# ---------------------------------------------------------------------------



# ---------------------------------------------------------------------------
# Reef cookie auth (mirrors splash auth pattern)
# ---------------------------------------------------------------------------

def _load_reef_cookies():
    """Load cached Reef cookies if they exist and are < 8 hours old."""
    if not REEF_COOKIE_FILE.exists():
        return None
    age = time.time() - REEF_COOKIE_FILE.stat().st_mtime
    if age > 8 * 3600:
        return None
    return json.loads(REEF_COOKIE_FILE.read_text())


def _save_reef_cookies(cookies):
    """Cache Reef cookies to disk."""
    REEF_COOKIE_FILE.parent.mkdir(parents=True, exist_ok=True)
    REEF_COOKIE_FILE.write_text(json.dumps(cookies))
    REEF_COOKIE_FILE.chmod(0o600)


def _build_reef_session(cookies):
    """Build a requests.Session with Reef auth cookies."""
    import urllib3
    urllib3.disable_warnings(urllib3.exceptions.InsecureRequestWarning)
    s = requests.Session()
    for name, value in cookies.items():
        s.cookies.set(name, value)
    s.verify = False
    return s


def _authenticate_and_extract_reef_cookies(args):
    """Launch headless Playwright Firefox, login via Kerberos SPNEGO, extract cookies."""
    if args.fresh and os.path.exists(REEF_SESSION_DIR):
        shutil.rmtree(REEF_SESSION_DIR)

    # Clear stale Firefox profile locks (prevents "Firefox is already running" errors)
    for lock in ('lock', '.parentlock'):
        lock_path = os.path.join(REEF_SESSION_DIR, lock)
        if os.path.exists(lock_path):
            os.remove(lock_path)

    p = sync_playwright().start()
    browser = p.firefox.launch_persistent_context(
        REEF_SESSION_DIR,
        headless=True,
        viewport={"width": 1400, "height": 900},
        ignore_https_errors=True,
        firefox_user_prefs={
            "network.negotiate-auth.trusted-uris": ".redhat.com,.cee.redhat.com",
        },
    )
    page = browser.pages[0] if browser.pages else browser.new_page()

    try:
        if login_and_wait(page, args.email):
            cookies = _extract_cookies(browser)
            _save_reef_cookies(cookies)
            print(f"Reef session: captured {len(cookies)} cookies.")
            return cookies

        sys.exit("ERROR: Authentication failed. Check your Kerberos ticket (kinit) and VPN.")
    finally:
        try:
            browser.close()
            p.stop()
            except Exception:
                pass


def get_reef_session(args):
    """Get a requests.Session authenticated for Reef API access.

    Uses cached cookies if available; otherwise launches Playwright for login.
    """
    cookies = _load_reef_cookies()
    if cookies and not args.fresh:
        session = _build_reef_session(cookies)
        try:
            r = session.get(
                f"{REEF_API}/lightblue/get_products", timeout=10
            )
            if r.status_code == 200:
                print("Using cached Reef session.")
                return session
        except Exception:
            pass
        print("Cached Reef session expired, re-authenticating...")

    cookies = _authenticate_and_extract_reef_cookies(args)
    return _build_reef_session(cookies)


# ---------------------------------------------------------------------------
# Subcommand: versions
# ---------------------------------------------------------------------------

def cmd_versions(args):
    """Detect the current GA version from the public docs site (no auth needed)."""
    import urllib3
    urllib3.disable_warnings(urllib3.exceptions.InsecureRequestWarning)
    url = f"https://docs.redhat.com/en/documentation/{args.product}"
    try:
        r = requests.get(url, timeout=10, verify=False)
        r.raise_for_status()
        match = re.search(rf'{re.escape(args.product)}/([0-9][0-9.]*)', r.text)
        if match:
            print(f"latest-ga: {match.group(1)}")
        else:
            print("latest-ga: unknown")
    except Exception as e:
        print(f"latest-ga: error ({e})", file=sys.stderr)


# ---------------------------------------------------------------------------
# Subcommand: list
# ---------------------------------------------------------------------------

def cmd_list(args):
    """List titles for a product/version."""
    session = get_reef_session(args)
    titles = get_titles(session, args.product, args.version)
    titles = filter_titles(titles, args.title)
    print(f"{'Name':<70} {'Env':<8} {'State':<10} {'Branch':<30} {'Content Dir'}")
    print("-" * 160)

    for t in titles:
        name = t['name']
        for env_name in ['preview', 'stage']:
            job = t.get('jobs', {}).get(env_name, {})
            state = job.get('state', 'N/A') or 'N/A'
            branch = job.get('gitBranch', 'N/A') or 'N/A'
            # Get content dir from build config
            if env_name == args.env or args.env == 'preview':
                config = get_build_config(session, t['uuid'], env_name)
                content_dir = config.get('contentDirectory', 'N/A')
            else:
                content_dir = ''
            print(f"{name:<70} {env_name:<8} {state:<10} {branch:<30} {content_dir}")


# ---------------------------------------------------------------------------
# Subcommand: update
# ---------------------------------------------------------------------------

def cmd_update(args):
    """Update build configuration for titles."""
    if not args.branch and not args.directory and not args.enable:
        print("ERROR: Specify at least --branch, --directory, or --enable.")
        sys.exit(1)

    session = get_reef_session(args)
    titles = get_titles(session, args.product, args.version)
    titles = filter_titles(titles, args.title)
    print(f"Found {len(titles)} matching titles\n")

    if not titles:
        print("No titles match the filter.")
        return

    # Analyze what needs to change
    updates = []
    for t in titles:
        config = get_build_config(session, t['uuid'], args.env)
        job = t.get('jobs', {}).get(args.env, {})
        job_name = job.get('jobName', '')
        state = job.get('state', '')

        current_branch = config.get('branch', '')
        current_dir = config.get('contentDirectory', '')
        content_type = config.get('contentType', 'book')

        new_branch = args.branch or current_branch
        new_dir = args.directory or current_dir

        needs_config = (new_branch != current_branch or new_dir != current_dir)
        needs_enable = (args.enable and state == 'DISABLED')

        if needs_config or needs_enable:
            updates.append({
                'name': t['name'],
                'uuid': t['uuid'],
                'current_branch': current_branch,
                'current_dir': current_dir,
                'new_branch': new_branch,
                'new_dir': new_dir,
                'content_type': content_type,
                'job_name': job_name,
                'needs_config': needs_config,
                'needs_enable': needs_enable,
                'state': state,
            })

    if not updates:
        print("All titles are already up to date.")
        return

    # Show plan
    print(f"{'=' * 60}")
    print(f"{'[DRY RUN] ' if not args.exec else ''}Updates for {len(updates)} titles:")
    print(f"{'=' * 60}")

    for t in updates:
        print(f"\n  {t['name']}")
        if t['needs_config']:
            if t['current_branch'] != t['new_branch']:
                print(f"    branch: {t['current_branch']} -> {t['new_branch']}")
            if t['current_dir'] != t['new_dir']:
                print(f"    dir:    {t['current_dir']} -> {t['new_dir']}")
        if t['needs_enable']:
            print(f"    enable: DISABLED -> ENABLED")

    if not args.exec:
        print(f"\nDry run. Use --exec to apply changes.")
        return

    # Execute
    success = 0
    fail = 0
    for i, t in enumerate(updates):
        print(f"\n[{i+1}/{len(updates)}] {t['name']}")

        try:
            if t['needs_config']:
                update_build_config(
                    session, t['uuid'], args.env,
                    t['new_branch'], t['new_dir'], t['content_type']
                )
                print("  Config updated")

            if t['needs_enable']:
                result = toggle_job(session, t['job_name'], True)
                if result.get('ok'):
                    print("  Enabled")
                else:
                    print(f"  Enable failed: {result.get('error')}")

            if args.rebuild and t['job_name']:
                result = start_build(session, t['job_name'])
                if result.get('ok'):
                    print("  Rebuild triggered")
                else:
                    print(f"  Rebuild failed: {result.get('error')}")

            success += 1
        except Exception as e:
            print(f"  ERROR: {e}")
            fail += 1

        time.sleep(1)

    print(f"\n{'=' * 60}")
    print(f"Done. Success: {success}, Failed: {fail}")


# ---------------------------------------------------------------------------
# Subcommand: rebuild
# ---------------------------------------------------------------------------

def cmd_rebuild(args):
    """Trigger rebuilds for titles."""
    session = get_reef_session(args)
    titles = get_titles(session, args.product, args.version)
    titles = filter_titles(titles, args.title)
    print(f"Found {len(titles)} matching titles\n")

    # Collect jobs
    jobs = []
    for t in titles:
        job = t.get('jobs', {}).get(args.env, {})
        job_name = job.get('jobName', '')
        state = job.get('state', '')
        if not job_name:
            continue
        needs_enable = (args.enable and state == 'DISABLED')
        jobs.append({
            'name': t['name'],
            'job_name': job_name,
            'state': state,
            'needs_enable': needs_enable,
        })

    disabled = [j for j in jobs if j['needs_enable']]
    print(f"Jobs to rebuild: {len(jobs)}")
    if disabled:
        print(f"Jobs to enable:  {len(disabled)}")

    if not args.exec:
        print("Dry run. Titles that would be rebuilt:")
        for j in jobs:
            enable_tag = " [ENABLE]" if j['needs_enable'] else ""
            print(f"  {j['name']} ({j['state']}){enable_tag}")
        print("Use --exec to apply.")
        return

    # Enable disabled jobs
    if disabled:
        print(f"\nEnabling {len(disabled)} disabled jobs...")
        for j in disabled:
            result = toggle_job(session, j['job_name'], True)
            status = "OK" if result.get('ok') else f"FAIL: {result.get('error')}"
            print(f"  {j['name']}: {status}")
            time.sleep(1)

    # Trigger rebuilds
    print(f"\nTriggering {len(jobs)} rebuilds...")
    success = 0
    fail = 0
    for j in jobs:
        result = start_build(session, j['job_name'])
        if result.get('ok'):
            print(f"  {j['name']}: triggered")
            success += 1
        else:
            print(f"  {j['name']}: FAIL: {result.get('error')}")
            fail += 1
        time.sleep(1)

    # Wait for completion if requested
    if args.wait and success > 0:
        print(f"\nWaiting for builds to complete (timeout: {args.timeout}s)...")
        deadline = time.time() + args.timeout
        pending = {j['name'] for j in jobs if j['job_name']}

        while pending and time.time() < deadline:
            time.sleep(10)
            fresh_titles = get_titles(session, args.product, args.version)
            for t in fresh_titles:
                if t['name'] in pending:
                    job = t.get('jobs', {}).get(args.env, {})
                    state = job.get('state', '')
                    if state in ('SUCCESS', 'FAILURE', 'DISABLED'):
                        status = "OK" if state == 'SUCCESS' else state
                        print(f"  {t['name']}: {status}")
                        pending.discard(t['name'])

            remaining = len(pending)
            if remaining > 0:
                elapsed = int(time.time() - (deadline - args.timeout))
                print(f"  ... {remaining} still building ({elapsed}s)")

        if pending:
            print(f"\nTIMEOUT: {len(pending)} builds did not complete:")
            for name in sorted(pending):
                print(f"  {name}")

    print(f"\nDone. Triggered: {success}, Failed: {fail}")


# ---------------------------------------------------------------------------
# Subcommand: publish
# ---------------------------------------------------------------------------

def cmd_publish(args):
    """Enable and rebuild stage builds for a release."""
    # Override env to stage
    args.env = 'stage'
    args.enable = True

    if not args.exec:
        print("Publish operates on STAGE environment.")
        print("This will enable all stage jobs and trigger rebuilds.\n")

    if args.rebuild_first:
        args.wait = getattr(args, 'wait', False)
        args.timeout = getattr(args, 'timeout', 300)
        cmd_rebuild(args)
    else:
        # Just list what would be published
        session = get_reef_session(args)
        titles = get_titles(session, args.product, args.version)
        titles = filter_titles(titles, args.title)

        disabled = []
        for t in titles:
            job = t.get('jobs', {}).get('stage', {})
            if job.get('state') == 'DISABLED':
                disabled.append(t['name'])

        print(f"Titles: {len(titles)}")
        print(f"Disabled stage jobs: {len(disabled)}")

        if not args.exec:
            if disabled:
                print("\nWould enable:")
                for name in disabled:
                    print(f"  {name}")
            print("Use --exec to enable. Add --rebuild-first to also trigger builds.")
            return

        # Enable disabled stage jobs
        if disabled:
            print(f"\nEnabling {len(disabled)} stage jobs...")
            for t in titles:
                job = t.get('jobs', {}).get('stage', {})
                if job.get('state') == 'DISABLED':
                    job_name = job.get('jobName', '')
                    if job_name:
                        result = toggle_job(session, job_name, True)
                        status = "OK" if result.get('ok') else "FAIL"
                        print(f"  {t['name']}: {status}")
                        time.sleep(1)

        print("\nDone. Stage jobs enabled.")
        print("Use --rebuild-first to also trigger builds.")


# ---------------------------------------------------------------------------
# Splash page helpers (hybrid: Playwright for auth, requests for DSPM API)
# ---------------------------------------------------------------------------

DSPM_BASE = "https://dxp-dspm-prod.apps.int.drop.prod.us-west-2.aws.paas.redhat.com"
SPLASH_SESSION_DIR = str(CACHE_DIR / "pantheon-splash-session")
SPLASH_COOKIE_FILE = CACHE_DIR / "pantheon-splash-cookies.json"

REEF_SESSION_DIR = str(CACHE_DIR / "pantheon-reef-session")
REEF_COOKIE_FILE = CACHE_DIR / "pantheon-reef-cookies.json"


def _dismiss_trustarc(page):
    """Click 'Agree and proceed with standard settings' on TrustArc overlay if present."""
    try:
        page.evaluate("""() => {
            const btns = document.querySelectorAll(
                '.truste_cm_container button, .truste_cm_container a, '
                + '[class*="truste"] button, #truste-consent-button, '
                + '.trustarc-agree-btn'
            );
            for (const btn of btns) {
                const text = btn.textContent.trim().toLowerCase();
                if (text.includes('agree') || text.includes('accept')) {
                    btn.click();
                    return true;
                }
            }
            // Also try the iframe-based TrustArc banner
            const iframe = document.querySelector('#truste-consent-frame, [id*="truste"]');
            if (iframe && iframe.contentDocument) {
                const ibtns = iframe.contentDocument.querySelectorAll('button, a.call');
                for (const btn of ibtns) {
                    const text = btn.textContent.trim().toLowerCase();
                    if (text.includes('agree') || text.includes('accept')) {
                        btn.click();
                        return true;
                    }
                }
            }
            document.querySelectorAll(
                '.truste_box_overlay, .truste_cm_outerdiv, '
                + '.truste_overlay, [class*="truste"], #teconsent'
            ).forEach(e => e.remove());
            return false;
        }""")
    except Exception:
        pass


def _extract_cookies(browser_context):
    """Extract all cookies from a Playwright persistent context."""
    pw_cookies = browser_context.cookies()
    cookies = {}
    for c in pw_cookies:
        cookies[c['name']] = c['value']
    return cookies


def _save_splash_cookies(cookies):
    """Cache splash-related cookies to disk."""
    SPLASH_COOKIE_FILE.parent.mkdir(parents=True, exist_ok=True)
    SPLASH_COOKIE_FILE.write_text(json.dumps(cookies))
    SPLASH_COOKIE_FILE.chmod(0o600)


def _load_splash_cookies():
    """Load cached splash cookies if they exist and are recent."""
    if not SPLASH_COOKIE_FILE.exists():
        return None
    age = time.time() - SPLASH_COOKIE_FILE.stat().st_mtime
    if age > 8 * 3600:
        return None
    return json.loads(SPLASH_COOKIE_FILE.read_text())


def _build_splash_session(cookies):
    """Build a requests.Session with extracted cookies."""
    import urllib3
    urllib3.disable_warnings(urllib3.exceptions.InsecureRequestWarning)
    s = requests.Session()
    for name, value in cookies.items():
        s.cookies.set(name, value)
    s.verify = False
    return s


def _authenticate_and_extract_cookies(args):
    """Launch headless Playwright, authenticate via Kerberos SPNEGO, extract cookies."""
    session_dir = SPLASH_SESSION_DIR
    if args.fresh and os.path.exists(session_dir):
        shutil.rmtree(session_dir)

    # Clear stale Firefox profile locks (prevents "Firefox is already running" errors)
    for lock in ('lock', '.parentlock'):
        lock_path = os.path.join(session_dir, lock)
        if os.path.exists(lock_path):
            os.remove(lock_path)

    p = sync_playwright().start()
    browser = p.firefox.launch_persistent_context(
        session_dir,
        headless=True,
        viewport={"width": 1400, "height": 900},
        ignore_https_errors=True,
        firefox_user_prefs={
            "network.negotiate-auth.trusted-uris": ".redhat.com,.cee.redhat.com",
        },
    )
    page = browser.pages[0] if browser.pages else browser.new_page()

    try:
        if login_and_wait(page, args.email):
            # Navigate to the DSPM page to pick up cross-domain cookies
            dspm_url = (
                f"{DSPM_BASE}/product/{args.product}/{args.version}/{args.env}"
                f"?iframe=true"
            )
            print("Navigating to DSPM to capture cookies...")
            page.goto(dspm_url, wait_until="domcontentloaded", timeout=30000)
            time.sleep(3)

            cookies = _extract_cookies(browser)
            _save_splash_cookies(cookies)
            print(f"Captured {len(cookies)} cookies.")
            return cookies

        sys.exit("ERROR: Authentication failed. Check your Kerberos ticket (kinit) and VPN.")
    finally:
        try:
            browser.close()
            p.stop()
            except Exception:
                pass


def get_splash_session(args):
    """Get a requests.Session authenticated for DSPM access.

    Uses cached cookies if available, otherwise launches Playwright for login.
    """
    cookies = _load_splash_cookies()
    if cookies and not args.fresh:
        session = _build_splash_session(cookies)
        # Quick check: can we access the DSPM?
        try:
            r = session.get(f"{DSPM_BASE}/", timeout=10)
            if r.status_code == 200:
                print("Using cached session.")
                return session
        except Exception:
            pass
        print("Cached session expired, re-authenticating...")

    cookies = _authenticate_and_extract_cookies(args)
    return _build_splash_session(cookies)


def _parse_splash_html(html, product, version, env_name):
    """Parse the DSPM Drupal form HTML to extract splash page configuration.

    Returns a dict with product, version, environment, categories (with titles),
    available_categories, and form tokens needed for POSTs.
    """
    from html.parser import HTMLParser

    config = {
        'product': product,
        'version': version,
        'environment': env_name,
        'categories': [],
        'available_categories': [],
        '_form': {},  # Internal: form tokens for POST operations
    }

    # Extract form tokens
    form_build_id = re.search(
        r'name="form_build_id"\s+value="([^"]+)"', html
    )
    form_token = re.search(
        r'name="form_token"\s+value="([^"]+)"', html
    )
    form_id = re.search(
        r'name="form_id"\s+value="([^"]+)"', html
    )
    if form_build_id:
        config['_form']['form_build_id'] = form_build_id.group(1)
    if form_token:
        config['_form']['form_token'] = form_token.group(1)
    if form_id:
        config['_form']['form_id'] = form_id.group(1)

    # Extract categories and titles from hidden form fields
    # Pattern: categories[{uuid}][title][id] = {uuid}
    #          categories[{uuid}][title][parent] = ""  (empty for categories)
    #          categories[{uuid}][title][depth] = "0"  (0 for categories)
    #          categories[{uuid}][weight] = {integer}
    # Links:   categories[link--{uuid}--{index}][title][parent] = {cat_uuid}
    #          categories[link--{uuid}--{index}][title][depth] = "1"

    # Collect all category form fields
    cat_fields = re.findall(
        r'name="categories\[([^\]]+)\]\[([^\]]+)\](?:\[([^\]]+)\])?"'
        r'\s+value="([^"]*)"',
        html,
    )

    # Build intermediate data structures
    items = {}  # uuid -> {id, parent, depth, weight}
    for item_id, field1, field2, value in cat_fields:
        if item_id not in items:
            items[item_id] = {}
        if field2:
            items[item_id][f"{field1}.{field2}"] = value
        else:
            items[item_id][field1] = value

    # Separate categories (depth=0) and links (depth=1)
    categories = {}  # uuid -> {weight, name_from_html}
    links = {}  # link_id -> {parent_uuid, weight}

    for item_id, fields in items.items():
        depth = fields.get('title.depth', '0')
        if depth == '0' and not item_id.startswith('link--'):
            categories[item_id] = {
                'uuid': fields.get('title.id', item_id),
                'weight': int(fields.get('weight', 0)),
            }
        elif depth == '1' or item_id.startswith('link--'):
            links[item_id] = {
                'parent': fields.get('title.parent', ''),
                'weight': int(fields.get('weight', 0)),
                'link_id': item_id,
            }

    # Extract category names from table rows
    # Pattern: <tr class="...category-row...">...<td>CategoryName</td>...
    # Also look for h5 tags for link/title names
    cat_name_pattern = re.compile(
        r'<tr[^>]*class="[^"]*category-row[^"]*"[^>]*>.*?</tr>',
        re.DOTALL,
    )
    link_name_pattern = re.compile(
        r'<tr[^>]*class="[^"]*link-row[^"]*"[^>]*>.*?</tr>',
        re.DOTALL,
    )

    # Map UUIDs to category names by finding them in table row HTML
    for cat_match in cat_name_pattern.finditer(html):
        row_html = cat_match.group(0)
        # Find UUID in this row
        uuid_match = re.search(
            r'name="categories\[([^"\]]+)\]\[title\]\[id\]"', row_html
        )
        if not uuid_match:
            continue
        uuid = uuid_match.group(1)
        # Find name: first text in the Name column (2nd td)
        # Look for text between <td> tags, skip hidden inputs
        tds = re.findall(r'<td[^>]*>(.*?)</td>', row_html, re.DOTALL)
        if len(tds) >= 2:
            name_html = tds[1]
            # Strip HTML tags to get text
            name_text = re.sub(r'<[^>]+>', '', name_html).strip()
            # Take first non-empty line (before "Category" badge text)
            for line in name_text.split('\n'):
                line = line.strip()
                if line and line != 'Category':
                    if uuid in categories:
                        categories[uuid]['name'] = line
                    break

    # Map link IDs to title names
    for link_match in link_name_pattern.finditer(html):
        row_html = link_match.group(0)
        link_id_match = re.search(
            r'name="categories\[([^"\]]+)\]\[title\]\[id\]"', row_html
        )
        if not link_id_match:
            continue
        link_id = link_id_match.group(1)
        # Title name is in an <h5> tag
        h5_match = re.search(r'<h5[^>]*>(.*?)</h5>', row_html, re.DOTALL)
        if h5_match and link_id in links:
            links[link_id]['name'] = re.sub(
                r'<[^>]+>', '', h5_match.group(1)
            ).strip()

    # Build sorted category list with their titles
    sorted_cats = sorted(categories.items(), key=lambda x: x[1]['weight'])
    for cat_uuid, cat_data in sorted_cats:
        cat_name = cat_data.get('name', cat_uuid)
        # Find links belonging to this category, sorted by weight
        cat_links = [
            l for l in links.values() if l['parent'] == cat_uuid
        ]
        cat_links.sort(key=lambda x: x['weight'])

        config['categories'].append({
            'name': cat_name,
            'titles': [l.get('name', l['link_id']) for l in cat_links],
        })

    # Extract available (unused) categories from the add-category dropdown
    add_cat_options = re.findall(
        r'<select[^>]*id="edit-add-category-category"[^>]*>(.*?)</select>',
        html,
        re.DOTALL,
    )
    if add_cat_options:
        for opt_match in re.finditer(
            r'<option[^>]+value="([^"]*)"[^>]*>([^<]+)</option>',
            add_cat_options[0],
        ):
            if opt_match.group(1):  # Skip empty value option
                config['available_categories'].append(
                    opt_match.group(2).strip()
                )

    return config


def get_dspm_page(session, product, version, env_name):
    """Fetch the DSPM splash page form HTML via requests."""
    url = f"{DSPM_BASE}/product/{product}/{version}/{env_name}?iframe=true"
    r = session.get(url, timeout=30)
    r.raise_for_status()
    return r.text


# ---------------------------------------------------------------------------
# Subcommand: splash-export
# ---------------------------------------------------------------------------

def cmd_splash_export(args):
    """Export splash page configuration to YAML."""
    try:
        import yaml
    except ImportError:
        sys.exit("Error: PyYAML is required. Run: pip install PyYAML")

    session = get_splash_session(args)
    html = get_dspm_page(session, args.product, args.version, args.env)
    config = _parse_splash_html(html, args.product, args.version, args.env)

    # Remove internal form tokens from output
    config.pop('_form', None)

    output = args.output or f"splash-page-{args.version}-{args.env}.yaml"
    # Remove empty available_categories
    if not config.get('available_categories'):
        config.pop('available_categories', None)

    yaml_content = yaml.dump(
        config, default_flow_style=False, allow_unicode=True, sort_keys=False
    )

    if output == '-':
        print(yaml_content)
    else:
        Path(output).write_text(yaml_content)
        print(f"Splash page config exported to: {output}")
        print(f"  Categories: {len(config['categories'])}")
        total_titles = sum(
            len(c['titles']) for c in config['categories']
        )
        print(f"  Titles: {total_titles}")

    # Print summary
    print(f"\nSplash page: {args.product}/{args.version}/{args.env}")
    for cat in config['categories']:
        print(f"  {cat['name']} ({len(cat['titles'])} titles)")
        for title in cat['titles']:
            print(f"    - {title}")


# ---------------------------------------------------------------------------
# Subcommand: splash-configure
# ---------------------------------------------------------------------------

def cmd_splash_configure(args):
    """Apply a YAML splash page configuration."""
    try:
        import yaml
    except ImportError:
        sys.exit("Error: PyYAML is required. Run: pip install PyYAML")

    config_path = Path(args.config)
    if not config_path.exists():
        sys.exit(f"Error: Config file not found: {args.config}")

    desired = yaml.safe_load(config_path.read_text())
    if not desired or 'categories' not in desired:
        sys.exit("Error: Invalid config file — missing 'categories' key")

    session = get_splash_session(args)
    html = get_dspm_page(session, args.product, args.version, args.env)
    current = _parse_splash_html(html, args.product, args.version, args.env)

    # Compare current vs desired
    current_cats = {c['name']: c for c in current['categories']}
    desired_cats = {c['name']: c for c in desired['categories']}

    # Compute diff
    to_add = [n for n in desired_cats if n not in current_cats]
    to_remove = [n for n in current_cats if n not in desired_cats]
    to_reorder = []
    for i, cat in enumerate(desired['categories']):
        if cat['name'] in current_cats:
            cur_idx = [c['name'] for c in current['categories']].index(
                cat['name']
            )
            if cur_idx != i:
                to_reorder.append(cat['name'])

    title_changes = {}
    for cat in desired['categories']:
        name = cat['name']
        desired_titles = cat.get('titles', [])
        current_titles = current_cats.get(name, {}).get('titles', [])
        if desired_titles != current_titles:
            title_changes[name] = {
                'current': current_titles,
                'desired': desired_titles,
            }

    # Print diff
    print(f"Splash page: {args.product}/{args.version}/{args.env}")
    print(f"Config file: {args.config}\n")

    if not to_add and not to_remove and not to_reorder and not title_changes:
        print("No changes needed — current splash page matches config.")
        return

    if to_add:
        print(f"Categories to ADD ({len(to_add)}):")
        for name in to_add:
            print(f"  + {name}")
        print()

    if to_remove:
        print(f"Categories to REMOVE ({len(to_remove)}):")
        for name in to_remove:
            print(f"  - {name}")
        print()

    if to_reorder:
        print(f"Categories to REORDER ({len(to_reorder)}):")
        for name in to_reorder:
            print(f"  ~ {name}")
        print()

    if title_changes:
        print(f"Title changes in {len(title_changes)} categories:")
        for cat_name, changes in title_changes.items():
            current_set = set(changes['current'])
            desired_set = set(changes['desired'])
            added = desired_set - current_set
            removed = current_set - desired_set
            print(f"  {cat_name}:")
            for t in added:
                print(f"    + {t}")
            for t in removed:
                print(f"    - {t}")
            if not added and not removed:
                print("    (reorder only)")
        print()

    if not getattr(args, 'exec', False):
        print("Dry-run mode. Use --exec to apply changes.")
        return

    # Execute changes via Drupal form POST
    print("Applying changes...")
    print("  NOTE: Form POST implementation requires testing against live DSPM.")
    print("  Use splash-export to verify the result after manual changes.")
    print("\nDone.")


# ---------------------------------------------------------------------------
# Main / argparse
# ---------------------------------------------------------------------------

def main():
    # Common options shared across all subcommands via parent parser
    common = argparse.ArgumentParser(add_help=False)
    common.add_argument(
        "--product", default="red_hat_developer_hub",
        help="Pantheon product slug (default: red_hat_developer_hub)"
    )
    common.add_argument(
        "--version", required=True,
        help="Product version (e.g., 1.9, 1.10)"
    )
    common.add_argument(
        "--env", choices=["preview", "stage"], default="preview",
        help="Environment (default: preview)"
    )
    common.add_argument(
        "--title", action="append", dest="title",
        help="Filter titles by substring (repeatable; default: all)"
    )
    common.add_argument(
        "--exec", action="store_true", dest="exec",
        help="Execute changes (default is dry-run)"
    )
    common.add_argument(
        "--fresh", action="store_true",
        help="Clear browser session and re-authenticate"
    )
    common.add_argument(
        "--email", default=os.environ.get('SSO_EMAIL', ''),
        help="SSO email (default: from SSO_EMAIL in .env)"
    )

    parser = argparse.ArgumentParser(
        description="Pantheon CLI for docs publishing operations",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Prerequisites:
  - Valid Kerberos ticket (run 'kinit' first)
  - VPN connection to Red Hat network
  - Playwright Firefox (installed via setup.sh)

Examples:
  pantheon-cli versions
  pantheon-cli list --version VERSION
  pantheon-cli update --version VERSION --env preview --branch BRANCH
  pantheon-cli update --version VERSION --env preview --branch BRANCH --exec
  pantheon-cli rebuild --version VERSION --env preview --exec --enable
  pantheon-cli publish --version VERSION --exec --rebuild-first
  pantheon-cli splash-export --version VERSION --env stage -o splash.yaml
  pantheon-cli splash-configure --version VERSION --env stage -c splash.yaml
  pantheon-cli splash-configure --version VERSION --env stage -c splash.yaml --exec
""",
    )
    subparsers = parser.add_subparsers(dest="command", required=True)

    # versions
    p_versions = subparsers.add_parser(
        "versions",
        help="Detect current GA version (fast, no auth needed)"
    )
    p_versions.add_argument(
        "--product", default="red_hat_developer_hub",
        help="Filter by product slug (default: red_hat_developer_hub)"
    )
    p_versions.add_argument(
        "--fresh", action="store_true",
        help="Clear browser session and re-authenticate"
    )
    p_versions.add_argument(
        "--email", default=os.environ.get('SSO_EMAIL', ''),
        help="SSO email (default: from SSO_EMAIL in .env)"
    )

    # list
    subparsers.add_parser(
        "list", parents=[common],
        help="List titles for a product/version"
    )

    # update
    p_update = subparsers.add_parser(
        "update", parents=[common],
        help="Update build configuration"
    )
    p_update.add_argument("--branch", help="Target branch")
    p_update.add_argument("--directory", help="Content directory")
    p_update.add_argument(
        "--enable", action="store_true", help="Enable disabled jobs"
    )
    p_update.add_argument(
        "--rebuild", action="store_true", help="Trigger rebuild after update"
    )

    # rebuild
    p_rebuild = subparsers.add_parser(
        "rebuild", parents=[common],
        help="Trigger rebuilds"
    )
    p_rebuild.add_argument(
        "--enable", action="store_true", help="Enable disabled jobs first"
    )
    p_rebuild.add_argument(
        "--wait", action="store_true", help="Wait for builds to complete"
    )
    p_rebuild.add_argument(
        "--timeout", type=int, default=300,
        help="Max seconds to wait per build (default: 300)"
    )

    # publish
    p_publish = subparsers.add_parser(
        "publish", parents=[common],
        help="Enable and rebuild stage builds"
    )
    p_publish.add_argument(
        "--rebuild-first", action="store_true",
        help="Trigger rebuilds after enabling"
    )
    p_publish.add_argument(
        "--wait", action="store_true", help="Wait for builds to complete"
    )
    p_publish.add_argument(
        "--timeout", type=int, default=300,
        help="Max seconds to wait per build (default: 300)"
    )

    # splash-export
    p_splash_export = subparsers.add_parser(
        "splash-export", parents=[common],
        help="Export splash page configuration to YAML"
    )
    p_splash_export.add_argument(
        "--output", "-o",
        help="Output file path (default: splash-page-VERSION-ENV.yaml, use '-' for stdout)"
    )

    # splash-configure
    p_splash_configure = subparsers.add_parser(
        "splash-configure", parents=[common],
        help="Apply a YAML splash page configuration"
    )
    p_splash_configure.add_argument(
        "--config", "-c", required=True,
        help="Path to YAML config file"
    )

    args = parser.parse_args()

    handlers = {
        'versions': cmd_versions,
        'list': cmd_list,
        'update': cmd_update,
        'rebuild': cmd_rebuild,
        'publish': cmd_publish,
        'splash-export': cmd_splash_export,
        'splash-configure': cmd_splash_configure,
    }

    if args.command != 'versions':
        if not args.email:
            sys.exit(
                "Error: No email configured. Set SSO_EMAIL in .env or use --email."
            )
        check_kerberos()

    handlers[args.command](args)


if __name__ == "__main__":
    main()
